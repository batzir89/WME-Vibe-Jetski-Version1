  "elevation": {
    "system": "Elevation Style",
    "description": "Elevation levels used to establish hierarchy. Levels 1-5 use a combination of 'Key' and 'Ambient' shadows to create depth.",
    "base_shadow_color": "rgb(60, 64, 67)",
    "base_shadow_color_name": "Grey800",
    "levels": [
      {
        "level": 0,
        "name": "Elevation 0",
        "description": "Default, no shadow. Uses a stroke/border instead.",
        "properties": {
          "type": "stroke",
          "width": "1px",
          "color": "#DBDCE0",
          "color_name": "Grey300"
        },
        "css_helper": "border: 1px solid #DBDCE0;"
      },
      {
        "level": 1,
        "name": "Elevation 1",
        "description": "Default shadowed state.",
        "properties": {
          "type": "shadow",
          "layers": [
            { "name": "Key", "opacity": 0.30, "x": "0", "y": "1px", "blur": "2px", "spread": "0" },
            { "name": "Ambient", "opacity": 0.15, "x": "0", "y": "1px", "blur": "3px", "spread": "1px" }
          ]
        },
        "css_helper": "box-shadow: 0 1px 2px 0 rgba(60, 64, 67, 0.30), 0 1px 3px 1px rgba(60, 64, 67, 0.15);"
      },
      {
        "level": 2,
        "name": "Elevation 2",
        "description": "Shadowed level 2.",
        "properties": {
          "type": "shadow",
          "layers": [
            { "name": "Key", "opacity": 0.30, "x": "0", "y": "1px", "blur": "2px", "spread": "0" },
            { "name": "Ambient", "opacity": 0.15, "x": "0", "y": "2px", "blur": "6px", "spread": "2px" }
          ]
        },
        "css_helper": "box-shadow: 0 1px 2px 0 rgba(60, 64, 67, 0.30), 0 2px 6px 2px rgba(60, 64, 67, 0.15);"
      },
      {
        "level": 3,
        "name": "Elevation 3",
        "description": "Shadowed level 3.",
        "properties": {
          "type": "shadow",
          "layers": [
            { "name": "Key", "opacity": 0.30, "x": "0", "y": "1px", "blur": "3px", "spread": "0" },
            { "name": "Ambient", "opacity": 0.15, "x": "0", "y": "4px", "blur": "8px", "spread": "3px" }
          ]
        },
        "css_helper": "box-shadow: 0 1px 3px 0 rgba(60, 64, 67, 0.30), 0 4px 8px 3px rgba(60, 64, 67, 0.15);"
      },
      {
        "level": 4,
        "name": "Elevation 4",
        "description": "Shadowed level 4.",
        "properties": {
          "type": "shadow",
          "layers": [
            { "name": "Key", "opacity": 0.30, "x": "0", "y": "2px", "blur": "3px", "spread": "0" },
            { "name": "Ambient", "opacity": 0.15, "x": "0", "y": "6px", "blur": "10px", "spread": "4px" }
          ]
        },
        "css_helper": "box-shadow: 0 2px 3px 0 rgba(60, 64, 67, 0.30), 0 6px 10px 4px rgba(60, 64, 67, 0.15);"
      },
      {
        "level": 5,
        "name": "Elevation 5",
        "description": "Shadowed level 5.",
        "properties": {
          "type": "shadow",
          "layers": [
            { "name": "Key", "opacity": 0.30, "x": "0", "y": "4px", "blur": "4px", "spread": "0" },
            { "name": "Ambient", "opacity": 0.15, "x": "0", "y": "8px", "blur": "12px", "spread": "6px" }
          ]
        },
        "css_helper": "box-shadow: 0 4px 4px 0 rgba(60, 64, 67, 0.30), 0 8px 12px 6px rgba(60, 64, 67, 0.15);"
      }
    ]
  },
  "typography": {
    "system": "Waze Typography",
